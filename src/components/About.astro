---
---

<section id="about" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-primary-500 font-semibold text-sm uppercase tracking-widest">Who I am</span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mt-2">About Me</h2>
      <div class="mt-4 mx-auto w-16 h-1 bg-accent-400 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: image / decorative card -->
      <div class="relative flex justify-center">
        <div class="relative w-72 sm:w-80">
          <!-- Main card -->
          <div class="w-full aspect-square rounded-3xl bg-gradient-to-br from-primary-100 to-primary-200 border border-primary-200 flex items-center justify-center shadow-xl">
            <div class="text-center p-8">
              <div class="w-20 h-20 rounded-2xl bg-primary-500 mx-auto mb-4 flex items-center justify-center shadow-lg">
                <span class="text-2xl font-black text-white">BC</span>
              </div>
              <p class="font-bold text-slate-700 text-lg">Bruno Cesano</p>
              <p class="text-primary-600 text-sm font-medium mt-1">Full-Stack Developer</p>
              <p class="text-slate-500 text-xs mt-2">Buenos Aires, Argentina</p>
            </div>
          </div>
          <!-- Floating accent badges -->
          <div class="absolute -top-4 -right-4 bg-accent-400 text-slate-900 text-xs font-bold px-3 py-1.5 rounded-full shadow-md rotate-3">
            Open to work
          </div>
          <div class="absolute -bottom-4 -left-4 bg-primary-600 text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-md -rotate-2">
            3+ years exp.
          </div>
        </div>
      </div>

      <!-- Right: text content -->
      <div class="space-y-6">
        <p class="text-slate-600 text-lg leading-relaxed">
          I'm a passionate developer based in Buenos Aires, Argentina. I love building things for the web — from
          pixel-perfect interfaces to solid backend systems.
        </p>
        <p class="text-slate-600 leading-relaxed">
          My journey in software started with curiosity and grew into a real craft. I enjoy
          the challenge of turning complex problems into simple, elegant solutions. When I'm not
          coding, I'm exploring new technologies, contributing to open-source, or learning
          about design systems.
        </p>
        <p class="text-slate-600 leading-relaxed">
          I care deeply about code quality, user experience, and continuous improvement. I'm always
          looking for opportunities to collaborate on interesting projects and grow as a developer.
        </p>

        <!-- Highlight cards -->
        <div class="grid grid-cols-2 gap-4 pt-2">
          <div class="bg-primary-50 border border-primary-100 rounded-2xl p-4">
            <div class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <p class="font-semibold text-slate-800 text-sm">Clean Code</p>
            <p class="text-slate-500 text-xs mt-1">Readable, maintainable, tested</p>
          </div>
          <div class="bg-accent-300/20 border border-accent-300/40 rounded-2xl p-4">
            <div class="w-8 h-8 rounded-lg bg-accent-400 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <p class="font-semibold text-slate-800 text-sm">Problem Solver</p>
            <p class="text-slate-500 text-xs mt-1">Analytical &amp; creative thinking</p>
          </div>
          <div class="bg-primary-50 border border-primary-100 rounded-2xl p-4">
            <div class="w-8 h-8 rounded-lg bg-primary-700 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <p class="font-semibold text-slate-800 text-sm">Performance</p>
            <p class="text-slate-500 text-xs mt-1">Fast, optimized experiences</p>
          </div>
          <div class="bg-accent-300/20 border border-accent-300/40 rounded-2xl p-4">
            <div class="w-8 h-8 rounded-lg bg-accent-500 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <p class="font-semibold text-slate-800 text-sm">Collaboration</p>
            <p class="text-slate-500 text-xs mt-1">Team-oriented mindset</p>
          </div>
        </div>

        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors"
        >
          Let's work together
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
