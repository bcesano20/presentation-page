---
// TODO: Update 3rd project preview
const projects = [
  {
    title: 'Presentation Page',
    description:
      'This personal website, built with Astro and Tailwind CSS. Optimized for performance and deployed on Vercel with zero configuration.',
    tags: ['Astro', 'Tailwind CSS', 'Vercel'],
    github: 'https://github.com/bcesano20/presentation-page',
    live: null,
    accent: true,
  },
  {
    title: 'Work Order Management System for a Service Provider',
    description:
      'Managemen system built with React and Django with an auth mechanism, management different entities of the context such as Clients, Technicians, Work Orders, etc. This work was used as my final project to get my degree in Engineering ',
    tags: ['React', 'Python', 'Django', 'REST APIs'],
    github: 'https://github.com/bcesano20/tesis-app',
    live: null,
    accent: false,
  },
  {
    title: 'Project Three',
    description:
      'Another project description. Replace this with your real project details, including the tech stack, your role, and what makes it interesting.',
    tags: ['Python', 'SQL', 'Docker'],
    github: 'https://github.com/bcesano20',
    live: null,
    accent: false,
  },
];
---

<section id="projects" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="text-primary-500 font-semibold text-sm uppercase tracking-widest">What I've built</span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mt-2">Projects</h2>
      <div class="mt-4 mx-auto w-16 h-1 bg-accent-400 rounded-full"></div>
      <p class="text-center w-full max-w-[1020px] text-lg mt-8 mx-auto text-slate-600">
        Over the last few years, I’ve worked on a variety of projects involving 
        real clients, gathering requirements, developing solutions, and maintaining 
        applications already in production. My experience includes both short and long-term 
        projects, where I collaborated on building and improving systems according to 
        business needs and user requirements.
      </p>
      <p class="text-center w-full max-w-[1020px] text-lg mt-3 mb-8 mx-auto text-slate-600">  
        Since many of these projects were developed professionally and cannot be
         publicly shared, I’m unable to showcase all of them here. However, below
          you can find some selected projects, along with a link to my GitHub 
          profile where I share personal work and additional examples of my development experience.
      </p>
    </div>


    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <article
          class={`group relative flex flex-col rounded-3xl border overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 ${
            project.accent
              ? 'bg-gradient-to-br from-primary-500 to-primary-700 border-primary-400 text-white'
              : 'bg-white border-primary-100 hover:border-primary-200'
          }`}
        >
          <!-- Card top accent line -->
          {!project.accent && (
            <div class="h-1 bg-gradient-to-r from-primary-400 to-accent-400 w-full"></div>
          )}
          {project.accent && (
            <div class="h-1 bg-accent-400 w-full"></div>
          )}

          <div class="flex flex-col flex-1 p-6">
            <!-- Icon -->
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-4 ${
              project.accent ? 'bg-white/20' : 'bg-primary-100'
            }`}>
              <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${project.accent ? 'text-white' : 'text-primary-600'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>

            <h3 class={`font-bold text-xl mb-2 ${project.accent ? 'text-white' : 'text-slate-900'}`}>
              {project.title}
            </h3>
            <p class={`text-sm leading-relaxed flex-1 mb-5 ${project.accent ? 'text-primary-100' : 'text-slate-500'}`}>
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${
                  project.accent
                    ? 'bg-white/15 text-white border border-white/20'
                    : 'bg-primary-50 text-primary-700 border border-primary-100'
                }`}>
                  {tag}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex items-center gap-3 mt-auto">
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class={`flex items-center gap-1.5 text-sm font-semibold transition-colors ${
                  project.accent
                    ? 'text-white hover:text-accent-300'
                    : 'text-slate-700 hover:text-primary-600'
                }`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
                GitHub
              </a>
              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`flex items-center gap-1.5 text-sm font-semibold transition-colors ${
                    project.accent
                      ? 'text-accent-300 hover:text-accent-400'
                      : 'text-primary-600 hover:text-primary-700'
                  }`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  Live demo
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View more link -->
    <div class="text-center mt-12">
      <a
        href="https://github.com/bcesano20"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary-50 text-primary-700 font-semibold rounded-full border border-primary-200 hover:bg-primary-100 hover:border-primary-300 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
        </svg>
        See all projects on GitHub
      </a>
    </div>

  </div>
</section>
