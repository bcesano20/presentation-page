---
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-white via-primary-50 to-primary-100 pt-16"
>
  <!-- Background decorative blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-200 rounded-full opacity-30 blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary-300 rounded-full opacity-20 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent-300 rounded-full opacity-5 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-8 flex flex-col lg:flex-row items-center gap-12 py-20">

    <!-- Text content -->
    <div class="flex-1 text-center lg:text-left">
      <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-medium px-4 py-1.5 rounded-full mb-6 border border-primary-200">
        <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
        Available for new opportunities
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-slate-900 leading-tight mb-4">
        Hi, I'm
        <span class="text-primary-500"> Bruno</span>
        <span class="block text-accent-500">Cesano.</span>
      </h1>

      <p class="text-xl sm:text-2xl text-slate-600 font-medium mb-4">
        Full-Stack Developer &amp; UI Enthusiast
      </p>

      <p class="text-base sm:text-lg text-slate-500 max-w-xl mx-auto lg:mx-0 mb-10 leading-relaxed">
        I build fast, modern, and accessible web experiences. Passionate about clean code,
        thoughtful design, and turning ideas into polished products.
      </p>

      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <a
          href="#projects"
          class="px-6 py-3 bg-primary-500 text-white font-semibold rounded-full hover:bg-primary-600 transition-all shadow-lg shadow-primary-200 hover:shadow-primary-300 hover:-translate-y-0.5"
        >
          View my work
        </a>
        <a
          href="#contact"
          class="px-6 py-3 bg-white text-slate-700 font-semibold rounded-full border border-slate-200 hover:border-primary-300 hover:text-primary-600 transition-all hover:-translate-y-0.5"
        >
          Get in touch
        </a>
      </div>

      <!-- Quick stats -->
      <div class="flex gap-8 mt-12 justify-center lg:justify-start">
        <div>
          <p class="text-2xl font-bold text-slate-900">3+</p>
          <p class="text-sm text-slate-500">Years coding</p>
        </div>
        <div class="w-px bg-slate-200"></div>
        <div>
          <p class="text-2xl font-bold text-slate-900">10+</p>
          <p class="text-sm text-slate-500">Projects built</p>
        </div>
        <div class="w-px bg-slate-200"></div>
        <div>
          <p class="text-2xl font-bold text-slate-900">5+</p>
          <p class="text-sm text-slate-500">Technologies</p>
        </div>
      </div>
    </div>

    <!-- Avatar / decorative card -->
    <div class="flex-shrink-0 relative">
      <div class="w-64 h-64 sm:w-80 sm:h-80 rounded-3xl bg-gradient-to-br from-primary-400 to-primary-600 shadow-2xl shadow-primary-200 flex items-center justify-center relative overflow-hidden">
        <!-- Initials placeholder — swap with <img> when you have a photo -->
        <span class="text-8xl font-black text-white/20 select-none">BC</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-6xl font-black text-white select-none">BC</span>
        </div>
        <!-- Yellow accent dot -->
        <div class="absolute -bottom-3 -right-3 w-16 h-16 bg-accent-400 rounded-2xl rotate-12 shadow-lg"></div>
        <div class="absolute -top-3 -left-3 w-10 h-10 bg-primary-200 rounded-xl -rotate-6"></div>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-400 text-xs animate-bounce">
    <span>Scroll down</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
