---
type Level = 'Basic' | 'Intermediate' | 'Advanced';

const levelConfig: Record<Level, { width: string; bar: string; badge: string }> = {
  Basic:        { width: '33%',  bar: 'from-slate-300 to-slate-400',       badge: 'bg-slate-100 text-slate-500' },
  Intermediate: { width: '66%',  bar: 'from-primary-300 to-primary-500',   badge: 'bg-primary-100 text-primary-700' },
  Advanced:     { width: '100%', bar: 'from-primary-500 to-accent-500',    badge: 'bg-accent-300/40 text-yellow-700' },
};

const skillGroups: { category: string; icon: string; skills: { name: string; level: Level }[] }[] = [
  {
    category: 'Frontend',
    icon: '🎨',
    skills: [
      { name: 'HTML5',        level: 'Advanced'     },
      { name: 'CSS3',         level: 'Advanced'     },
      { name: 'JavaScript',   level: 'Advanced'     },
      { name: 'TypeScript',   level: 'Advanced' },
      { name: 'React',        level: 'Advanced' },
      { name: 'Astro',        level: 'Intermediate' },
      { name: 'Tailwind CSS', level: 'Advanced'     },
    ],
  },
  {
    category: 'Backend',
    icon: '⚙️',
    skills: [
      { name: 'Node.js',   level: 'Intermediate' },
      { name: 'Python',    level: 'Advanced' },
      { name: 'REST APIs', level: 'Advanced' },
      { name: 'SQL',       level: 'Intermediate' },
    ],
  },
  {
    category: 'Tools & DevOps',
    icon: '🛠️',
    skills: [
      { name: 'Git',     level: 'Advanced'     },
      { name: 'GitHub',  level: 'Advanced'     },
      { name: 'VS Code', level: 'Advanced'     },
      { name: 'Docker',  level: 'Basic'        },
      { name: 'Vercel',  level: 'Intermediate' },
      { name: 'AWS',  level: 'Basic' },
      { name: 'Heroku',  level: 'Intermediate' }
    ],
  },
];
---

<section id="skills" class="py-24 bg-primary-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-8">

    <!-- Section header -->
    <div class="text-center mb-11">
      <span class="text-primary-500 font-semibold text-sm uppercase tracking-widest">What I work with</span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mt-2">Skills</h2>
      <div class="mt-4 mx-auto w-16 h-1 bg-accent-400 rounded-full"></div>
    </div>

    <p class="text-center w-full max-w-[1020px] text-lg mx-auto text-slate-600">
      Throughout the different projects I’ve worked on, I’ve had the opportunity to build 
      and maintain web applications using a variety of technologies across the full stack. 
      My experience includes developing dynamic and responsive interfaces with smooth and 
      complex interactions, integrating systems with databases and APIs, and building 
      reliable backend solutions for production environments.
    </p>
    <p class="text-center w-full max-w-[1020px] text-lg mt-3 mb-8 mx-auto text-slate-600">  
      I’ve worked on both short and long-term projects involving large volumes of data, 
      real-time maintenance, and applications such as giveaways, gaming platforms, 
      management systems, and business-focused solutions. From transforming client 
      requirements and designs into user-friendly interfaces to creating scalable APIs 
      and backend logic, these technologies have been part of real-world products used 
      in production environments. 
    </p>

    <!-- Skill groups grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {skillGroups.map((group) => (
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-primary-100 hover:shadow-md hover:border-primary-200 transition-all">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">{group.icon}</span>
            <h3 class="font-bold text-slate-800 text-lg">{group.category}</h3>
          </div>
          <div class="space-y-4">
            {group.skills.map((skill) => {
              const cfg = levelConfig[skill.level];
              return (
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="font-medium text-slate-700 text-sm">{skill.name}</span>
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${cfg.badge}`}>
                      {skill.level}
                    </span>
                  </div>
                  <div class="h-1.5 bg-primary-100 rounded-full overflow-hidden">
                    <div
                      class={`h-full bg-gradient-to-r ${cfg.bar} rounded-full`}
                      style={`width: ${cfg.width}`}
                    ></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
