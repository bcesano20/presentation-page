---
import HamburgerMenu from '../components/HamburgerMenu.astro';

interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = 'https://presentation-page-bruno.vercel.app/';

const {
  title       = 'Bruno Cesano — Full-Stack Developer & Computer Engineer',
  description = 'Personal website of Bruno Cesano, a Full-Stack Developer and Computer Engineer based in Barcelona. Building modern web applications with React, Django, Python, and more.',
} = Astro.props;

const navLinks = [
  { href: '#about',    label: 'About'    },
  { href: '#skills',   label: 'Skills'   },
  { href: '#projects', label: 'Projects' },
  { href: '#contact',  label: 'Contact'  },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="author"       content="Bruno Cesano" />
    <meta name="robots"       content="index, follow" />
    <link rel="canonical"     href={SITE_URL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <!-- Theme color (mobile browser bar) -->
    <meta name="theme-color" content="#0ea5e9" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={SITE_URL} />
    <meta property="og:site_name"   content="Bruno Cesano — Portfolio" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${SITE_URL}/og-image.png`} />
    <meta property="og:locale"      content="en_US" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white text-slate-800 font-sans antialiased">

    <!-- Navigation -->
    <header class="fixed top-0 inset-x-0 z-50 bg-white/90 backdrop-blur-sm border-b border-primary-100 shadow-sm">
      <nav class="max-w-6xl mx-auto px-4 sm:px-8 flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <span class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold text-sm group-hover:bg-primary-600 transition-colors">
            BC
          </span>
        </a>

        <!-- Desktop links — hidden below 900px -->
        <ul class="hidden nav:flex items-center gap-1">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 hover:text-primary-600 hover:bg-primary-50 transition-all"
              >
                {label}
              </a>
            </li>
          ))}
          <li>
            <a
              href="#contact"
              class="ml-2 px-4 py-1.5 rounded-full bg-accent-400 text-slate-900 text-sm font-semibold hover:bg-accent-300 transition-colors shadow-sm"
            >
              Hire me
            </a>
          </li>
        </ul>

        <!-- Hamburger — visible below 900px -->
        <HamburgerMenu />

      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-primary-950 text-primary-300 py-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm">
        <p>© 2026 <span class="text-white font-medium">Bruno Cesano</span>. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>
