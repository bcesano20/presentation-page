---
import HamburgerMenu from '../components/HamburgerMenu.astro';

interface Props {
  title?: string;
}
const { title = 'Bruno Cesano — Portfolio' } = Astro.props;

const navLinks = [
  { href: '#about',    label: 'About'    },
  { href: '#skills',   label: 'Skills'   },
  { href: '#projects', label: 'Projects' },
  { href: '#contact',  label: 'Contact'  },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bruno Cesano — Personal Portfolio" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white text-slate-800 font-sans antialiased">

    <!-- Navigation -->
    <header class="fixed top-0 inset-x-0 z-50 bg-white/90 backdrop-blur-sm border-b border-primary-100 shadow-sm">
      <nav class="max-w-6xl mx-auto px-4 sm:px-8 flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <span class="w-8 h-8 rounded-lg bg-primary-500 flex items-center justify-center text-white font-bold text-sm group-hover:bg-primary-600 transition-colors">
            BC
          </span>
          <span class="font-semibold text-slate-800">Bruno Cesano</span>
        </a>

        <!-- Desktop links — hidden below 900px -->
        <ul class="hidden nav:flex items-center gap-1">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="px-3 py-1.5 rounded-md text-sm font-medium text-slate-600 hover:text-primary-600 hover:bg-primary-50 transition-all"
              >
                {label}
              </a>
            </li>
          ))}
          <li>
            <a
              href="#contact"
              class="ml-2 px-4 py-1.5 rounded-full bg-accent-400 text-slate-900 text-sm font-semibold hover:bg-accent-300 transition-colors shadow-sm"
            >
              Hire me
            </a>
          </li>
        </ul>

        <!-- Hamburger — visible below 900px -->
        <HamburgerMenu />

      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-primary-950 text-primary-300 py-8">
      <div class="max-w-6xl mx-auto px-4 sm:px-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm">
        <p>© 2025 <span class="text-white font-medium">Bruno Cesano</span>. All rights reserved.</p>
        <p>Built with <span class="text-primary-300">Astro</span> &amp; <span class="text-primary-300">Tailwind CSS</span></p>
      </div>
    </footer>

  </body>
</html>
